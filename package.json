{
  "name": "obsidian-embedded-whiteboard",
  "version": "0.1.1",
  "description": "Obsidian plugin that embeds a canvas-like whiteboard directly in notes.",
  "main": "main.js",
  "scripts": {
    "build": "node esbuild.config.mjs",
    "dev": "node esbuild.config.mjs --watch",
    "package-release": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/package-release.ps1"
  },
  "devDependencies": {
    "@codemirror/state": "6.5.0",
    "@codemirror/view": "^6.38.6",
    "esbuild": "^0.25.1",
    "obsidian": "1.12.3",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  }
}

